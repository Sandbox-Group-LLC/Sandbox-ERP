generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  sid     String   @id
  sess    Json
  expire  DateTime

  @@index([expire])
  @@map("sessions")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String?
  logoDarkUrl  String?
  faviconUrl   String?
  googleRefreshToken    String?
  googleAccessToken     String?
  googleTokenExpiry     DateTime?
  googleConnectedEmail  String?
  googleConnectedAt     DateTime?
  googleOAuthNonce      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users                User[]
  clients              Client[]
  opportunities        Opportunity[]
  projects             Project[]
  templates            Template[]
  documentTemplates    DocumentTemplate[]
  vendors              Vendor[]
  people               Person[]
  staffingRoles        StaffingRole[]
  roleRates            RoleRate[]
  chatChannels         ChatChannel[]
  userInvites          UserInvite[]
  assets               Asset[]
  proofRequests        ProofRequest[]
  meetings             Meeting[]
  alertEvents          AlertEvent[]
  alertRuleConfigs     AlertRuleConfig[]
}

enum UserRole {
  ADMIN
  MEMBER
  EXTERNAL
  CLIENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

model User {
  id              String        @id
  email           String?       @unique
  passwordHash    String?
  name            String?
  firstName       String?
  lastName        String?
  profileImageUrl String?
  role            UserRole      @default(MEMBER)
  approvalStatus  ApprovalStatus @default(PENDING)
  approvedById    String?
  approvedBy      User?          @relation("UserApprovals", fields: [approvedById], references: [id])
  approvedUsers   User[]         @relation("UserApprovals")
  approvedAt      DateTime?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  lastMessagesReadAt DateTime?
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  ownedProjects      Project[]            @relation("ProjectOwner")
  assignedTasks      Task[]
  createdExpenses    ExpenseEntry[]       @relation("ExpenseCreator")
  createdActuals     ActualCostEntry[]    @relation("ActualCreator")
  pushSubscriptions  PushSubscription[]
  chatMessages       ChatMessage[]
  sentInvites        UserInvite[]         @relation("UserInvites")
  createdBudgetVersions BudgetVersion[]   @relation("BudgetVersionCreator")
  createdProofRequests ProofRequest[]     @relation("ProofRequestCreator")
  aiQueryLogs        AiQueryLog[]
  alertRecipients    AlertRecipient[]
  createdDocFolders  DocFolder[]
  uploadedDocFiles   DocFile[]
  docComments        DocComment[]
  expenseReports     ContractorExpenseReport[]  @relation("ExpenseReportSubmitter")
  expenseReportActivities ContractorExpenseActivity[] @relation("ExpenseReportActivityActor")
}

model UserInvite {
  id             String       @id @default(cuid())
  email          String
  token          String       @unique @default(cuid())
  role           UserRole     @default(MEMBER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invitedById    String
  invitedBy      User         @relation("UserInvites", fields: [invitedById], references: [id])
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([email, organizationId, acceptedAt])
}

model Client {
  id             String       @id @default(cuid())
  name           String
  clientCode     String?
  website        String?
  industry       String?
  address        String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  notes          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  contacts      Contact[]
  opportunities Opportunity[]
  projects      Project[]
  receivables   Receivable[]
  meetings      Meeting[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  role      String?
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OpportunityStage {
  Lead
  Qualified
  Proposal
  Won
  Lost
}

model Opportunity {
  id              String           @id @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  stage           OpportunityStage @default(Lead)
  budgetRange     String?
  eventType       String?
  activationState String?
  targetStartDate DateTime?
  eventStartDate  DateTime?
  eventEndDate    DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  project Project?
  budget  Budget?
}

enum ProjectStatus {
  Draft
  Active
  Onsite
  Closed
}

model Project {
  id              String        @id @default(cuid())
  name            String
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  opportunityId   String?       @unique
  opportunity     Opportunity?  @relation(fields: [opportunityId], references: [id])
  eventType       String?
  city            String?
  venue           String?
  startDate       DateTime?
  endDate         DateTime?
  status          ProjectStatus @default(Draft)
  ownerUserId     String?
  owner           User?         @relation("ProjectOwner", fields: [ownerUserId], references: [id])
  budgetThreshold Float?
  masterProductionDocUrl String?
  proofSheetId       String?
  proofSheetFolderId String?
  assetSheetId       String?
  assetSheetFolderId String?
  budgetSheetId       String?
  budgetSheetFolderId String?
  cateringSheetId       String?
  cateringSheetFolderId String?
  clientTeamMembers  Json?    @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  estimateVersions     EstimateVersion[]
  milestones           Milestone[]
  tasks                Task[]
  vendorQuotes         VendorQuote[]
  purchases            Purchase[]
  staffingAssignments  StaffingAssignment[]
  manualAdjustments    ManualAdjustment[]
  budget               Budget?
  expenseEntries       ExpenseEntry[]
  actualCostEntries    ActualCostEntry[]
  staffingPlan         StaffingPlan?
  contracts            Contract[]
  clientPortalAccess   ClientPortalAccess[]
  budgetComments       BudgetComment[]
  chatChannel          ChatChannel?
  shippingItems        ShippingItem[]
  receivables          Receivable[]
  assetReservations    AssetReservation[]
  proofRequests        ProofRequest[]
  meetings             Meeting[]
  runOfShows           RunOfShow[]
  aiQueryLogs          AiQueryLog[]
  alertEvents          AlertEvent[]
  budgetSnapshots      BudgetSnapshotDaily[]
  venueSearches        VenueSearch[]
  docFolders           DocFolder[]
  docFiles             DocFile[]
  contractorExpenseReports ContractorExpenseReport[]
  canvas               ProjectCanvas[]
  roomingLists         RoomingList[]
  housingHotels        HousingHotel[]
  cateringSettings     CateringSettings?
  cateringCategories   CateringCategory[]
  menuTemplates        MenuTemplate[]
}

enum EstimateStatus {
  Draft
  Approved
}

model EstimateVersion {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNumber Int
  status        EstimateStatus @default(Draft)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  lineItems EstimateLineItem[]

  @@unique([projectId, versionNumber])
}

enum PricingMode {
  PassThrough
  Markup
  Fixed
}

model EstimateLineItem {
  id                String          @id @default(cuid())
  estimateVersionId String
  estimateVersion   EstimateVersion @relation(fields: [estimateVersionId], references: [id], onDelete: Cascade)
  category          String
  description       String
  qty               Float           @default(1)
  unitCost          Float           @default(0)
  pricingMode       PricingMode     @default(PassThrough)
  markupPercent     Float?
  revenue           Float           @default(0)
  vendorId          String?
  vendor            Vendor?         @relation(fields: [vendorId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Template {
  id             String       @id @default(cuid())
  name           String
  eventType      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tasks TemplateTask[]
}

model TemplateTask {
  id                 String   @id @default(cuid())
  templateId         String
  template           Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title              String
  milestone          String?
  offsetDaysFromStart Int      @default(0)
  defaultOwnerRole   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DocumentTemplate {
  id             String       @id @default(cuid())
  name           String
  description    String?
  templateType   String       @default("Contract")
  googleDocUrl   String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]
}

enum TaskStatus {
  Todo
  InProgress
  Review
  Done
}

enum TaskWorkstream {
  MARKETING
  LOGISTICS
  CONTENT
  SPEAKERS
  SPONSORSHIP
  REGISTRATION
  PRODUCTION
  CREATIVE
  OPERATIONS
  OTHER
}

enum TaskPhase {
  PRE_PROGRAM
  LIVE
  POST_PROGRAM
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  milestoneId   String?
  milestone     Milestone?     @relation(fields: [milestoneId], references: [id])
  ownerUserId       String?
  owner             User?          @relation(fields: [ownerUserId], references: [id])
  assigneePersonId  String?
  assigneePerson    Person?        @relation(fields: [assigneePersonId], references: [id])
  dueDate           DateTime?
  executionTime DateTime?
  status        TaskStatus     @default(Todo)
  workstream    TaskWorkstream @default(OTHER)
  phase         TaskPhase      @default(PRE_PROGRAM)
  priority      TaskPriority   @default(MEDIUM)
  isMilestone   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  meetingExtractedTasks MeetingExtractedTask[]
}

model Vendor {
  id             String       @id @default(cuid())
  name           String
  email          String?
  phone          String?
  contactName        String?
  website            String?
  billingAddress     String?
  billingCity        String?
  billingState       String?
  billingZip         String?
  billingCountry     String?
  shippingAddress    String?
  shippingCity       String?
  shippingState      String?
  shippingZip        String?
  shippingCountry    String?
  taxId              String?
  notes              String?
  paymentTerms       String?
  categories     String?
  stripeAccountId          String?
  stripePayoutStatus       StripePayoutStatus @default(NOT_SETUP)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quotes                    VendorQuote[]
  purchases                 Purchase[]
  estimateLineItems         EstimateLineItem[]
  contracts                 Contract[]
  contractParticipants      ContractParticipant[] @relation("ContractVendorParticipant")
  shippingItems             ShippingItem[]
  venueSearchEntries        VenueSearchEntry[]
}

enum QuoteStatus {
  Draft
  Selected
  Rejected
}

model VendorQuote {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor      @relation(fields: [vendorId], references: [id])
  amount    Float       @default(0)
  notes     String?
  status    QuoteStatus @default(Draft)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum PurchaseStatus {
  Requested
  Approved
  Paid
}

enum TransactionType {
  CreditCard
  ACH
  Cash
}

model Purchase {
  id              String          @id @default(cuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  budgetLineId    String?
  budgetLine      BudgetLine?     @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  description     String
  amount          Float           @default(0)
  status          PurchaseStatus  @default(Requested)
  purchaserId     String?
  purchaser       Person?         @relation(fields: [purchaserId], references: [id], onDelete: SetNull)
  transactionType TransactionType?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([budgetLineId])
  @@index([purchaserId])
}

enum PersonType {
  Employee
  Freelancer
}

enum StripePayoutStatus {
  NOT_SETUP
  PENDING
  ACTIVE
  RESTRICTED
}

model Person {
  id              String       @id @default(cuid())
  firstName       String?
  lastName        String?
  name            String
  type            PersonType   @default(Employee)
  email           String?
  phone           String?
  defaultCostRate  Float        @default(0)
  defaultBillRate  Float        @default(0)
  clientBillRate   Float        @default(0)
  portfolioUrl     String?
  emergencyContactName  String?
  emergencyContactPhone String?
  stripeAccountId          String?
  stripePayoutStatus       StripePayoutStatus @default(NOT_SETUP)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  assignments          StaffingAssignment[]
  staffingAllocations  StaffingAllocation[]
  onboardingDocuments  OnboardingDocument[]
  contractParticipants ContractParticipant[]
  contracts            Contract[]
  assignedTasks        Task[]
  shippingItems        ShippingItem[]
  meetingExtractedTasks MeetingExtractedTask[]
  timeEntries          TimeEntry[]
  bankingInfo          PersonBankingInfo?
  purchases            Purchase[]
}

model PersonBankingInfo {
  id                String   @id @default(cuid())
  personId          String   @unique
  person            Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  
  accessToken       String   @unique
  expiresAt         DateTime
  lastAccess        DateTime?
  
  bankName          String?
  accountHolderName String?
  routingNumber     String?
  accountNumber     String?
  accountType       String?
  
  submittedAt       DateTime?
  submittedFromIp   String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum DocumentType {
  NDA
  COI
  W9
  CONTRACT
  DIRECT_DEPOSIT
  OTHER
}

enum DocumentStatus {
  PENDING
  RECEIVED
  VERIFIED
  EXPIRED
}

model OnboardingDocument {
  id            String         @id @default(cuid())
  personId      String
  person        Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  documentType  DocumentType
  status        DocumentStatus @default(PENDING)
  fileName      String?
  filePath      String?
  expirationDate DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([personId, documentType])
  @@index([personId])
}

enum StaffingState {
  Hold
  Confirmed
}

model StaffingAssignment {
  id             String        @id @default(cuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  staffingPlanId String?
  staffingPlan   StaffingPlan? @relation(fields: [staffingPlanId], references: [id], onDelete: Cascade)
  personId       String
  person         Person        @relation(fields: [personId], references: [id])
  roleId         String
  staffingRole   StaffingRole  @relation(fields: [roleId], references: [id])
  startDate      DateTime
  endDate        DateTime
  billRate         Decimal       @default(0) @db.Decimal(10, 2)
  costRate         Decimal       @default(0) @db.Decimal(10, 2)
  clientBillRate   Decimal       @default(0) @db.Decimal(10, 2)
  memo             String?
  state          StaffingState @default(Hold)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  allocations StaffingAllocation[]

  @@index([projectId])
  @@index([staffingPlanId])
  @@index([personId])
  @@index([roleId])
}

enum AdjustmentType {
  Cost
  Revenue
}

model ManualAdjustment {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  amount      Float          @default(0)
  type        AdjustmentType
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ============================================
// BUDGET ENGINE MODELS
// ============================================

model Budget {
  id             String       @id @default(cuid())
  projectId      String?      @unique
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  opportunityId  String?      @unique
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  jurisdiction   String       @default("California")
  baseMarkup     Float        @default(1.0)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines BudgetLine[]
  versions BudgetVersion[]
}

enum BudgetSection {
  PASSTHROUGH
  SANDBOX
  STAFFING
  SUMMARY
}

enum BudgetLineType {
  NORMAL
  STAFFING
  SUBTOTAL
}

enum BudgetCategory {
  VENUE_SERVICES
  GUEST_SERVICES
  ONSITE_SUPPORT
  AUDIO_VISUAL
  CATERING
  ENVIRONMENTAL
  CONTENT_DEVELOPMENT
  DIGITAL_SERVICES
  MERCHANDISE
  INSURANCE
  HEALTH_SAFETY
  TRAVEL_EXPENSES
  PRODUCTION_COSTS
}

model BudgetLine {
  id                String          @id @default(cuid())
  budgetId          String
  budget            Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  rowOrder          Int
  section           BudgetSection
  lineType          BudgetLineType  @default(NORMAL)
  category          BudgetCategory?
  taxCategory       String?
  description       String?
  ovh               Boolean        @default(false)
  vendor            String?
  units             Float          @default(1)
  internalCostInput Float?
  markupOverride    Float?
  internalNotes     String?
  clientNotes       String?
  processingFeeEnabled Boolean     @default(false)
  processingFeePercent Float       @default(5)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  expenseEntries    ExpenseEntry[]
  actualCostEntries ActualCostEntry[]
  purchases         Purchase[]
  roleLinks         BudgetLineRoleLink[]

  @@index([budgetId, rowOrder])
}

model BudgetVersion {
  id             String   @id @default(cuid())
  budgetId       String
  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  versionNumber  Int
  title          String
  notes          String?
  jurisdiction   String
  baseMarkup     Float
  isClientVisible Boolean @default(false)
  createdById    String?
  createdBy      User?    @relation("BudgetVersionCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())

  lines BudgetVersionLine[]

  @@unique([budgetId, versionNumber])
  @@index([budgetId])
}

model BudgetVersionLine {
  id                   String          @id @default(cuid())
  versionId            String
  version              BudgetVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  originalLineId       String?
  rowOrder             Int
  section              BudgetSection
  lineType             BudgetLineType  @default(NORMAL)
  category             BudgetCategory?
  taxCategory          String?
  description          String?
  ovh                  Boolean         @default(false)
  vendor               String?
  units                Float           @default(1)
  internalCostInput    Float?
  markupOverride       Float?
  internalNotes        String?
  clientNotes          String?
  processingFeeEnabled Boolean         @default(false)
  processingFeePercent Float           @default(5)

  @@index([versionId, rowOrder])
}

model TaxCode {
  id            String   @id @default(cuid())
  categoryCode  String
  jurisdiction  String
  taxRate       Float    @default(0)
  defaultMarkup Float    @default(1.0)
  isTaxable     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([categoryCode, jurisdiction])
  @@index([jurisdiction])
}

model StaffingRate {
  id           String   @id @default(cuid())
  roleName     String   @unique
  internalRate Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExpenseEntry {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetLineId    String?
  budgetLine      BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  date            DateTime    @default(now())
  vendor          String?
  description     String
  amount          Float       @default(0)
  notes           String?
  createdByUserId String?
  createdBy       User?       @relation("ExpenseCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([projectId, description])
  @@index([budgetLineId])
}

model ContractorExpenseReport {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation("ExpenseReportSubmitter", fields: [userId], references: [id])
  date            DateTime @default(now())
  amount          Float    @default(0)
  category        String?
  description     String
  receiptUrl      String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activities      ContractorExpenseActivity[]
  lineItems       ContractorExpenseLineItem[]

  @@index([projectId])
  @@index([userId])
  @@index([status])
}

model ContractorExpenseLineItem {
  id          String                  @id @default(cuid())
  reportId    String
  report      ContractorExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  category    String
  subCategory String?
  description String
  amount      Float                   @default(0)
  receiptUrl  String?
  createdAt   DateTime                @default(now())

  @@index([reportId])
}

model ContractorExpenseActivity {
  id          String                  @id @default(cuid())
  reportId    String
  report      ContractorExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actorUserId String
  actor       User                    @relation("ExpenseReportActivityActor", fields: [actorUserId], references: [id])
  action      String
  comment     String?
  createdAt   DateTime                @default(now())

  @@index([reportId])
}

model ActualCostEntry {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetLineId    String?
  budgetLine      BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  date            DateTime    @default(now())
  vendor          String?
  description     String
  amount          Float       @default(0)
  notes           String?
  createdByUserId String?
  createdBy       User?       @relation("ActualCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([projectId, description])
  @@index([budgetLineId])
}

model StaffingRole {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  roleRate          RoleRate?
  allocations       StaffingAllocation[]
  budgetLineLinks   BudgetLineRoleLink[]
  assignments       StaffingAssignment[]
  planRateOverrides StaffingPlanRoleRate[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model RoleRate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

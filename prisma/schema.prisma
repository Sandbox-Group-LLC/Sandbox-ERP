  priority        MeetingTaskPriority  @default(P1)
  category        MeetingTaskCategory  @default(OPS)
  
  createdTaskId   String?
  createdTask     Task?                @relation(fields: [createdTaskId], references: [id])
  
  createdAt       DateTime             @default(now())

  @@index([meetingId])
  @@index([createdTaskId])
  @@index([matchedPersonId])

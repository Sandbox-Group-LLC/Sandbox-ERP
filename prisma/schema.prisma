  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([venueSearchId])
  @@index([vendorId])
}

model DocFolder {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  files DocFile[]

  @@index([projectId])
}

model DocFile {
  id             String     @id @default(cuid())
  projectId      String
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         DocFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  name           String
  size           Int        @default(0)
  contentType    String     @default("application/octet-stream")
  storagePath    String
  uploadedById   String?
  uploadedBy     User?      @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  comments DocComment[]

  @@index([projectId])
  @@index([folderId])
}

model DocComment {
  id          String   @id @default(cuid())
  fileId      String
  file        DocFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  authorName  String
  content     String
  createdAt   DateTime @default(now())

  @@index([fileId])
}

model ProjectCanvas {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  canvasType   String   @default("internal")
  content      Json     @default("[]")
  lastEditedBy String?
  lastEditedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, canvasType])
  @@index([projectId])
}

// ============================================
// HOUSING - ROOMING LISTS
// ============================================

model RoomingList {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  dates       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guests      RoomingListGuest[]

  @@index([projectId])
}

model RoomingListGuest {
  id              String      @id @default(cuid())
  roomingListId   String
  roomingList     RoomingList @relation(fields: [roomingListId], references: [id], onDelete: Cascade)
  firstName       String      @default("")
  lastName        String      @default("")
  email           String      @default("")
  wwid            String      @default("")
  company         String      @default("")
  role            String      @default("")
  hotelId         String?
  rate            String      @default("")
  nights          Json        @default("{}")
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([roomingListId])
}

model HousingHotel {
  id                    String   @id @default(cuid())
  projectId             String
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                  String
  notes                 String   @default("")
  dates                 Json     @default("[]")
  contractedAttrition   Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  roomTypes   HousingRoomType[]
  taxFees     HousingTaxFee[]

  @@index([projectId])
}

model HousingRoomType {
  id              String        @id @default(cuid())
  hotelId         String
  hotel           HousingHotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name            String
  minNightStay    Int           @default(1)
  description     String        @default("")
  inventory       Json          @default("{}")
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([hotelId])
}

model CateringSettings {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorName        String   @default("")
  menuLink          String   @default("")
  minimumSpend      Float    @default(0)
  serviceChargePct  Float    @default(0)
  taxPct            Float    @default(0)
  dietaryNotes      String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CateringCategory {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       CateringItem[]

  @@index([projectId])
}

model CateringItem {
  id              String           @id @default(cuid())
  categoryId      String
  category        CateringCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  beoNumber       String           @default("")
  date            String           @default("")
  functionName    String           @default("")
  startTime       String           @default("")
  endTime         String           @default("")
  room            String           @default("")
  menuDescription String           @default("")
  pax             Int              @default(0)
  retailPrice     Float            @default(0)
  discountedPrice Float?
  banquetCheck    Float?
  notes           String           @default("")
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([categoryId])
}

model HousingTaxFee {
  id          String        @id @default(cuid())
  hotelId     String
  hotel       HousingHotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  type        String        @default("PERCENTAGE")
  value       Float         @default(0)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([hotelId])
}

model CronState {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model MenuTemplate {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  sourceFileName   String?
  serviceChargePct Float    @default(0)
  taxPct           Float    @default(0)
  minimumGuests    Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categories       MenuTemplateCategory[]

  @@index([projectId])
}

model MenuTemplateCategory {
  id         String   @id @default(cuid())
  templateId String
  template   MenuTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int      @default(0)

  items      MenuTemplateItem[]

  @@index([templateId])
}

model MenuTemplateItem {
  id               String   @id @default(cuid())
  categoryId       String
  category         MenuTemplateCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  pricePerPerson   Float?
  additionalFee    Float?
  additionalFeeNote String?
  notes            String?
  sortOrder        Int      @default(0)

  @@index([categoryId])
}
